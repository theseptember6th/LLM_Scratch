   "source": [
    "from langchain_core.runnables import RunnableLambda\n",
    "\n",
    "def word_count(text:str)->int:\n",
    "    return len(text.split())\n",
    "\n",
    "\n",
    "runnable_word_counter=RunnableLambda(word_count)\n",
    "result=runnable_word_counter.invoke(\n",
    "     \"Hi how are you?\"\n",
    ")\n",
    "print(result)"
   ]
  }
